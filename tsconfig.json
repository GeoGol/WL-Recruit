{
  "compilerOptions": {
    "target": "es2017",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
//    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "jsx": "react",
    "lib": ["es2017", "dom"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
